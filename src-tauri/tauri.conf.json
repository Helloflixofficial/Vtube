{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PNG VTuber",
  "version": "0.1.0",
  "identifier": "com.vtuber.pngvtuber",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PNG VTuber",
        "width": 420,
        "height": 580,
        "minWidth": 280,
        "minHeight": 380,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
